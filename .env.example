INQUIRY_RECIPIENT_EMAIL=sales@yourdomain.com
# Multiple recipients are supported with commas:
# INQUIRY_RECIPIENT_EMAIL=sales@yourdomain.com,info@yourdomain.com

INQUIRY_SMTP_HOST=webhost.dynadot.com
INQUIRY_SMTP_PORT=587
INQUIRY_SMTP_SECURE=false
INQUIRY_SMTP_USER=sales@yourdomain.com
INQUIRY_SMTP_PASS=your_app_password_or_smtp_password

INQUIRY_FROM_EMAIL=sales@yourdomain.com
INQUIRY_FROM_NAME=来自官网的咨询

# Optional fallback if you prefer forwarding to another service instead of SMTP.
INQUIRY_WEBHOOK_URL=
